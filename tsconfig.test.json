{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "rootDir": ".",
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "packages/**/*.test.ts",
    "packages/**/*.test.tsx",
    "apps/**/*.test.ts",
    "apps/**/*.test.tsx"
  ]
}
