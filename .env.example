# Protect all /v1 routes. Use a long random value in real deployments.
FETCHMUX_API_KEY=
FETCHMUX_AUTH_DISABLED=false
FETCHMUX_ALLOWED_ORIGINS=
FETCHMUX_HOST=127.0.0.1
FETCHMUX_PORT=8787

# Provider credentials stay in the server process. Never expose them to the site.
BRAVE_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Configure these from the customer's actual provider plan.
# A provider with unknown cost is excluded when maxCostUsd is supplied.
BRAVE_COST_PER_REQUEST_USD=
TAVILY_COST_PER_CREDIT_USD=
EXA_COST_PER_REQUEST_USD=
FIRECRAWL_COST_PER_REQUEST_USD=

# Optional public-site contact destination. Hidden when blank.
VITE_PILOT_CONTACT_URL=
