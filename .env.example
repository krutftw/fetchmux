# Protect all /v1 routes. Use a long random value in real deployments.
FETCHMUX_API_KEY=
# During zero-downtime rotation, provide comma-separated old and new gateway keys here.
FETCHMUX_API_KEYS=
FETCHMUX_AUTH_DISABLED=false
FETCHMUX_ALLOWED_ORIGINS=
FETCHMUX_HOST=127.0.0.1
FETCHMUX_PORT=8787

# MCP/SDK client destination. This is not used by the gateway process itself.
FETCHMUX_BASE_URL=http://127.0.0.1:8787/

# Provider credentials stay in the server process. Never expose them to the site.
# Keep each credential blank until its account and terms are approved.
BRAVE_API_KEY=
# The separating comments also prevent secret scanners from joining adjacent empty values.
TAVILY_API_KEY=
# Keep blank rather than using a fake credential that would make readiness misleading.
EXA_API_KEY=
# The final founding provider is also disabled by default.
FIRECRAWL_API_KEY=

# Optional free scholarly-metadata provider. Explicit opt-in prevents unexpected egress.
CROSSREF_ENABLED=false
CROSSREF_CONTACT_EMAIL=

# Configure these from the customer's actual provider plan.
# A provider with unknown cost is excluded when maxCostUsd is supplied.
BRAVE_COST_PER_REQUEST_USD=
TAVILY_COST_PER_CREDIT_USD=
EXA_COST_PER_REQUEST_USD=
FIRECRAWL_COST_PER_REQUEST_USD=

# Recorded by live benchmark reports. Set this to the tested commit SHA.
FETCHMUX_CODE_VERSION=

# Optional public-site contact destination. Hidden when blank.
VITE_PILOT_CONTACT_URL=
